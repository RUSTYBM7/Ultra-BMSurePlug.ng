{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/",
    "VITE_API_URL": "@vite_api_url",
    "VITE_PAYSTACK_PUBLIC_KEY": "@vite_paystack_public_key"
  }
}
